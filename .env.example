# ══════════════════════════════════════════════════════════════════════════════
# .env.example — ISNA Platform V2 (monorepo racine)
#
# Ce fichier liste les variables d'environnement minimales pour démarrer
# le projet en développement local.
#
# Chaque application a son propre .env.example plus complet :
#   apps/api/.env.example            ← API NestJS (variables serveur)
#   apps/app/.env.example            ← Admin app (variables VITE_*)
#   apps/med-app/.env.example        ← Interface praticien
#   apps/patient-portal/.env.example ← Portail patient
#   apps/public-site/.env.example    ← Site public Next.js
#   apps/worker/.env.example         ← Worker jobs asynchrones
#
# Pour le déploiement staging :
#   cp .env.staging.example .env.staging
#   # Remplir toutes les valeurs "replace_me"
#   bash scripts/deploy-all-staging.sh
# ══════════════════════════════════════════════════════════════════════════════

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API NestJS (apps/api) ─────────────────────────────────────────────────────
PORT=4002

# Supabase — Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_ANON_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me

# LiveKit — https://cloud.livekit.io
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_URL=wss://your-project.livekit.cloud

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me

# IA / LLM (au moins une clé requise pour les features IA)
ANTHROPIC_API_KEY=replace_me
OPENAI_API_KEY=replace_me
DEEPSEEK_API_KEY=replace_me

# Email — https://resend.com/api-keys
RESEND_API_KEY=replace_me
RESEND_FROM=noreply@yourdomain.com

# ── MEDOS Embedding (Mode C — widget JS / iframe sur sites tiers) ───────────
# Secret HMAC pour signer les JWT embed-token courts (15 min).
# OBLIGATOIRE pour activer POST /v1/medos/embed/token.
# Générer : openssl rand -hex 64
MEDOS_EMBED_JWT_SECRET=replace_me_with_random_hex_64

# Base API publique utilisée dans la réponse embed-token (le widget l'utilise
# pour ses appels). En dev local : http://localhost:4002
MEDOS_API_BASE=http://localhost:4002

# ── Admin App (apps/app) ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4002
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# ── Patient Portal (apps/patient-portal) ────────────────────────────────────
VITE_PP_API_URL=http://localhost:4002
VITE_PP_SUPABASE_URL=https://your-project.supabase.co
VITE_PP_SUPABASE_ANON_KEY=replace_me

# ── Med App (apps/med-app) ───────────────────────────────────────────────────
VITE_MED_API_URL=http://localhost:4002
VITE_MED_SUPABASE_URL=https://your-project.supabase.co
VITE_MED_SUPABASE_ANON_KEY=replace_me

# ── Public Site (apps/public-site) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4002
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
