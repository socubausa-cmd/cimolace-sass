# ══════════════════════════════════════════════════════════════════════════════
# .env.production.example — Cimolace sur Vercel + API publique
#
# Usage :
#   cp .env.production.example .env.production
#   # Remplir les valeurs replace_me
#   bash scripts/deploy-app-vercel.sh --prod
#
# Domaine front Cimolace : https://cimolace.space
# Domaine API recommandé : https://api.cimolace.space
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=4002

# ── URLs publiques ────────────────────────────────────────────────────────────
API_URL=https://api.cimolace.space
APP_URL=https://cimolace.space
PUBLIC_SITE_URL=https://cimolace.space
FRONTEND_URL=https://cimolace.space
CORS_ALLOWED_ORIGINS=https://cimolace.space,https://www.cimolace.space

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://replace_me.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_ANON_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me

# ── Cimolace Backoffice ───────────────────────────────────────────────────────
CIMOLACE_BACKOFFICE_ADMIN_EMAILS=admin@cimolace.space

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_URL=wss://replace_me.livekit.cloud

# ── Stripe / checkout ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_BILLING_WEBHOOK_SECRET=replace_me

# ── Mobile money optionnel ────────────────────────────────────────────────────
CINETPAY_API_KEY=replace_me
CINETPAY_SITE_ID=replace_me
CHARIOW_API_KEY=replace_me
PAWAPAY_API_TOKEN=replace_me
PAWAPAY_SIGNING_SECRET=replace_me
# Production par defaut: https://api.pawapay.io
# PAWAPAY_BASE_URL=https://api.pawapay.io

# ── IA ────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=replace_me
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
GROQ_API_KEY=replace_me

# ── Email / SMS ───────────────────────────────────────────────────────────────
RESEND_API_KEY=replace_me
RESEND_FROM=noreply@cimolace.space
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=replace_me

# ── Frontend Vite injecté par Vercel ──────────────────────────────────────────
VITE_API_URL=https://api.cimolace.space
VITE_SUPABASE_URL=https://replace_me.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
VITE_LIVEKIT_URL=wss://replace_me.livekit.cloud
VITE_APP_ENV=production
