NODE_ENV=development
PORT=4002

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_ANON_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me

# ── LiveKit (vidéo temps réel) ────────────────────────────────────────────────
# Obtenir depuis https://cloud.livekit.io → votre projet → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_BILLING_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PLAN_STARTER_PRICE_ID=price_replace_me
STRIPE_PLAN_PRO_PRICE_ID=price_replace_me
STRIPE_PLAN_BUSINESS_PRICE_ID=price_replace_me
STRIPE_PRICE_SCHOOL_STARTER=price_replace_me
STRIPE_PRICE_SCHOOL_PRO=price_replace_me
STRIPE_PRICE_SCHOOL_BUSINESS=price_replace_me

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4002
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── IA / LLM ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
OPENAI_API_KEY=replace_me
GROQ_API_KEY=replace_me

# ── LIRI Embed JWT ────────────────────────────────────────────────────────────
# Secret JWT pour les tokens embed du widget LIRI Live (WordPress, Wix, etc.)
# Générer avec : node -e "require('crypto').randomBytes(48).toString('hex')"
# Minimum 32 caractères. NE JAMAIS committer la valeur réelle.
LIRI_EMBED_JWT_SECRET=replace_me

# ── MedOS ─────────────────────────────────────────────────────────────────────
# Secret JWT pour les tokens embed MedOS (widget patient sur site médecin)
# Générer avec : node -e "require('crypto').randomBytes(48).toString('hex')"
MEDOS_JWT_SECRET=replace_me
MEDOS_EMBED_JWT_SECRET=replace_me
MEDOS_API_BASE=http://localhost:4002
SUPABASE_MEDICAL_BUCKET=med-private
MED_DATA_RETENTION_YEARS=10
MED_AUDIT_LOG_ENABLED=true

# ── Paiements Afrique ─────────────────────────────────────────────────────────
CINETPAY_API_KEY=replace_me
CHARIOW_API_KEY=replace_me

# ── Vidéo / Stockage cloud ────────────────────────────────────────────────────
MUX_TOKEN_ID=replace_me
MUX_TOKEN_SECRET=replace_me
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_STREAM_TOKEN=replace_me
# Cloudflare R2 (recordings LiveKit)
CF_R2_ACCOUNT_ID=replace_me
CF_R2_ACCESS_KEY_ID=replace_me
CF_R2_SECRET_ACCESS_KEY=replace_me
CF_R2_BUCKET=replace_me

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_API_V2_MARKETING=true
USE_API_V2_FORUM=false
USE_API_V2_BILLING=false

# ── Zoom Engine (cloud recordings pipeline) ────────────────────────────────────
# Obtenir depuis https://marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
ZOOM_CLIENT_ID=replace_me
ZOOM_CLIENT_SECRET=replace_me
ZOOM_REDIRECT_URI=http://localhost:4002/zoom-engine/oauth/callback
# Clé AES-256 pour chiffrer les tokens Zoom (32 bytes en hex = 64 caractères hex)
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ZOOM_TOKEN_ENCRYPTION_KEY=replace_me_with_64_hex_chars

# ── Social Publisher (TikTok, Facebook, Instagram) ─────────────────────────────
# TikTok : https://developers.tiktok.com → Apps → créer une app → Content Posting API
# Facebook : https://developers.facebook.com → créer une app → Graph API + Pages
TIKTOK_CLIENT_ID=replace_me
TIKTOK_CLIENT_SECRET=replace_me
FACEBOOK_APP_ID=replace_me
FACEBOOK_APP_SECRET=replace_me

# ── Service-to-service (worker → API) ──────────────────────────────────────────
# Générer un token aléatoire pour l'authentification interne worker → API
API_SERVICE_KEY=replace_me_with_random_string
