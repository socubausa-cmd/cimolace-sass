NODE_ENV=development
PORT=4000

SUPABASE_URL=https://new-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
# Dashboard → Project Settings → JWT Keys → JWT Secret (signing)
SUPABASE_JWT_SECRET=replace_me
# Optionnel : si la vérif échoue, fixe l’émetteur / audience des access tokens
# SUPABASE_JWT_ISSUER=https://new-project.supabase.co/auth/v1
# SUPABASE_JWT_AUD=authenticated

LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_URL=replace_me

STRIPE_SECRET_KEY=replace_me
# Obtenu via : stripe listen --forward-to localhost:4000/checkout/webhook/stripe
STRIPE_WEBHOOK_SECRET=replace_me
# URL du frontend app (pour les redirects Stripe success/cancel)
FRONTEND_URL=http://localhost:3001
CINETPAY_API_KEY=replace_me
CHARIOW_API_KEY=replace_me

OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
GROQ_API_KEY=replace_me

SENTRY_DSN=replace_me
