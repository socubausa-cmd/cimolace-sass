VITE_APP_ENV=v2-dev
VITE_APP_NAME=ISNA Platform V2

# Tenant par défaut (Cimolace est multi-tenant ; isna = 1er tenant).
# Résolu sinon par domaine / URL /t/:slug. Cf. docs/CIMOLACE_ARCHITECTURE.md §7.
VITE_DEFAULT_TENANT_SLUG=isna

# API NestJS
VITE_API_URL=http://localhost:4000

# Supabase V2 — remplacer par les vraies valeurs
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me

# LiveKit Cloud
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Feature flags
VITE_USE_API_V2_MARKETING=true
VITE_USE_API_V2_FORUM=true
VITE_USE_API_V2_BILLING=true

# Billing
VITE_BILLING_GRACE_DAYS=0

# Stripe (client-side only — publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Anthropic / DeepSeek / OpenAI (utilisés par LIRI via l'API)
# Les clés sont gérées côté serveur (API NestJS)
