{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/media/ambient/calm.mp3", "destination": "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3" },
    { "source": "/media/ambient/lofi.mp3", "destination": "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" },
    { "source": "/media/ambient/focus.mp3", "destination": "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3" },
    { "source": "/media/ambient/soft.mp3", "destination": "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-8.mp3" },
    { "source": "/media/ambient/warm.mp3", "destination": "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-7.mp3" },
    { "source": "/media/ambient/deep.mp3", "destination": "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-11.mp3" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "prorascience.org" }], "destination": "/prorascience.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.prorascience.org" }], "destination": "/prorascience.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "cimolace.space" }], "destination": "/cimolace.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.cimolace.space" }], "destination": "/cimolace.html" },
    { "source": "/creer-organisation(.*)", "has": [{ "type": "host", "value": "app.cimolace.space" }], "destination": "/cimolace.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
