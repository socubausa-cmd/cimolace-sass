  hero: { ...StyleSheet.absoluteFillObject },
  heroOff: {
    backgroundColor: C.rail,
    alignItems: 'center',
    justifyContent: 'center',
    gap: 12,
  },
  heroOffTxt: { color: C.faint, fontSize: 14, fontFamily: F.sans },

  topBar: {
    position: 'absolute',
    top: 0,
    left: 0,
    right: 0,
    paddingHorizontal: 16,
    paddingTop: 8,
    gap: 8,
  },
