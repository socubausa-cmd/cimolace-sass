    fontWeight: '800',
    letterSpacing: 1,
    fontFamily: F.sans,
  },
  timerPill: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 5,
    backgroundColor: 'rgba(31,30,28,0.78)',
    borderRadius: 8,
    paddingHorizontal: 9,
    paddingVertical: 5,
  },
  timerTxt: {
    color: C.ink,
    fontSize: 12.5,
    fontWeight: '700',
    fontVariant: ['tabular-nums'],
    fontFamily: F.sans,
  },
  topTitle: {
    color: '#fff',
    fontSize: 16,
    fontWeight: '600',
    fontFamily: F.serif,
    textShadowColor: 'rgba(0,0,0,0.6)',
    textShadowOffset: { width: 0, height: 1 },
    textShadowRadius: 4,
  },

  gridWrap: { position: 'absolute', left: 0, right: 0, bottom: 116 },
  gridContent: { paddingHorizontal: 14, gap: 10 },
  tile: {
    width: 108,
