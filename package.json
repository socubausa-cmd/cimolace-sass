{
  "name": "cimolace",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/app",
    "apps/med-app",
    "apps/patient-portal",
    "apps/public-site",
    "apps/worker",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w @isna/api",
    "dev:app": "npm run dev -w @isna/app",
    "dev:public-site": "npm run dev -w @isna/public-site",
    "dev:worker": "npm run dev -w @isna/worker",
    "build": "npm run build --workspaces --if-present",
    "dev:med-app": "npm run dev -w @isna/med-app",
    "dev:patient-portal": "npm run dev -w @isna/patient-portal",
    "test:e2e:liri": "playwright test -c playwright.config.ts tests/e2e/liri-signup-flow.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "reflect-metadata": "^0.1.14"
  }
}
