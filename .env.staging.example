# ══════════════════════════════════════════════════════════════════════════════
# .env.staging.example — ISNA Platform V2
#
# Usage :
#   cp .env.staging.example .env.staging
#   # Remplir toutes les valeurs "replace_me"
#   bash scripts/deploy-all-staging.sh
#
# Ce fichier couvre toutes les apps du monorepo :
#   apps/api           → PORT 4002, préfixe sans VITE_
#   apps/app           → VITE_APP_*
#   apps/patient-portal → VITE_PP_* (ou VITE_*)
#   apps/med-app       → VITE_MED_*
#   apps/public-site   → NEXT_PUBLIC_*
#   apps/worker        → prefixe sans VITE_
# ══════════════════════════════════════════════════════════════════════════════

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=4002

# ── URLs publiques ────────────────────────────────────────────────────────────
API_URL=https://api.staging.cimolace.com
APP_URL=https://app.staging.cimolace.com
PUBLIC_SITE_URL=https://staging.cimolace.com
MED_APP_URL=https://med.staging.cimolace.com
PATIENT_PORTAL_URL=https://patient.staging.cimolace.com

# ── Supabase (projet dédié staging) ──────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://replace_me.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_ANON_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me

# ── GCP / Cloud Run ───────────────────────────────────────────────────────────
# Projet GCP qui héberge le service Cloud Run de l'API
GCLOUD_PROJECT=cimolace-staging
GCLOUD_REGION=europe-west1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.staging.cimolace.com,https://med.staging.cimolace.com,https://patient.staging.cimolace.com,https://staging.cimolace.com

# ── Cimolace Backoffice ───────────────────────────────────────────────────────
CIMOLACE_BACKOFFICE_ADMIN_EMAILS=admin@cimolace.com

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Dashboard : https://cloud.livekit.io
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_URL=wss://replace_me.livekit.cloud

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_BILLING_WEBHOOK_SECRET=replace_me
FRONTEND_URL=https://app.staging.cimolace.com

# ── CinetPay ─────────────────────────────────────────────────────────────────
CINETPAY_API_KEY=replace_me
CINETPAY_SITE_ID=replace_me

# ── Chariow ───────────────────────────────────────────────────────────────────
CHARIOW_API_KEY=replace_me

# ── PawaPay ───────────────────────────────────────────────────────────────────
# Sandbox : https://dashboard.sandbox.pawapay.io
PAWAPAY_API_TOKEN=replace_me
PAWAPAY_SIGNING_SECRET=replace_me
# Décommenter pour forcer le sandbox
# PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=replace_me
PAYPAL_SECRET=replace_me

# ── NowPayments (crypto) ──────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=replace_me
NOWPAYMENTS_IPN_SECRET=replace_me

# ── IA / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
GROQ_API_KEY=replace_me
DEEPSEEK_API_KEY=replace_me

# ── MedOS — Transcription audio (Deepgram) ────────────────────────────────────
DEEPGRAM_API_KEY=replace_me

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=replace_me
RESEND_FROM=noreply@staging.cimolace.com

# ── SMS — Twilio ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=replace_me

# ── Vidéo — Cloudflare Stream + MUX ──────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_STREAM_TOKEN=replace_me
CLOUDFLARE_R2_ACCESS_KEY_ID=replace_me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace_me
CLOUDFLARE_R2_BUCKET=replace_me
MUX_TOKEN_ID=replace_me
MUX_TOKEN_SECRET=replace_me

# ── Images — Stability AI ─────────────────────────────────────────────────────
STABILITY_API_KEY=replace_me

# ── Worker — Inngest ──────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=replace_me
INNGEST_SIGNING_KEY=replace_me
REDIS_URL=replace_me

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=replace_me

# ══════════════════════════════════════════════════════════════════════════════
# FRONTENDS VITE (apps/app, apps/patient-portal, apps/med-app)
# Ces variables sont injectées via --build-env dans les scripts Vercel.
# Elles sont listées ici pour référence — ne pas les dupliquer dans .env.staging
# si elles sont déjà définies sous leur forme sans préfixe VITE_ ci-dessus.
# ══════════════════════════════════════════════════════════════════════════════
VITE_API_URL=https://api.staging.cimolace.com
VITE_SUPABASE_URL=https://replace_me.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
VITE_LIVEKIT_URL=wss://replace_me.livekit.cloud
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
VITE_APP_ENV=staging

# ── Public site Next.js ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.staging.cimolace.com
NEXT_PUBLIC_SUPABASE_URL=https://replace_me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
